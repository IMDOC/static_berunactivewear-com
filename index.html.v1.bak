<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Language" content="en">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Custom Activewear Manufacturer | OEM, ODM &amp; Private Label — Berun Active Wear</title>
    <meta name="description" content="Custom activewear manufacturer running OEM cut-and-sew, ODM, private label, in-house sampling and team-set sublimation under one 8,500 m² roof. MOQ 300 total piece count, sampling at USD 45 in 5 working days, ΔE ≤1.5 batch-to-batch. OEKO-TEX, BSCI, WRAP, GRS, Higg certified.">
    <meta name="keywords" content="custom activewear manufacturer, OEM activewear factory, ODM sportswear, private label activewear, sublimation team uniforms, low MOQ activewear, custom leggings manufacturer, sports bra manufacturer, custom team jersey, athleisure manufacturer">
    <meta name="author" content="Berun Active Wear">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <link rel="canonical" href="https://www.berunactivewear.com/">

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" href="/favicon.ico">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#DC2626">

    <meta property="og:type" content="website">
    <meta property="og:locale" content="en_US">
    <meta property="og:url" content="https://www.berunactivewear.com/">
    <meta property="og:title" content="Custom Activewear Manufacturer — OEM, ODM and Private Label | Berun Active Wear">
    <meta property="og:description" content="MOQ 300 total piece count split flexibly XS-XXL · Sampling USD 45 in 5 working days · ΔE ≤1.5 batch-to-batch · 12 lines, 280 staff, 8,500 m² single-site factory.">
    <meta property="og:image" content="https://www.berunactivewear.com/assets/images/hero-factory-bg.webp">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="Berun Active Wear">
    <meta name="twitter:card" content="summary_large_image">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://www.berunactivewear.com/#org",
      "name": "Berun Active Wear",
      "url": "https://www.berunactivewear.com/",
      "logo": "https://www.berunactivewear.com/assets/images/logo.svg",
      "foundingDate": "2017",
      "numberOfEmployees": {"@type": "QuantitativeValue", "value": 280},
      "description": "Custom activewear manufacturer specializing in OEM cut-and-sew, ODM, private label and team-set sublimation. Single-site 8,500 m² factory with 12 production lines.",
      "address": {"@type": "PostalAddress", "addressCountry": "CN", "addressLocality": "Guangzhou"},
      "contactPoint": {"@type": "ContactPoint", "email": "sales@berunactivewear.com", "contactType": "sales", "availableLanguage": ["English"]},
      "hasCredential": [
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "OEKO-TEX Standard 100", "identifier": "23.HCN.74521"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "BSCI", "identifier": "BSCI-CN-2024-08-15"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "WRAP Gold", "identifier": "WRAP-GLD-156823"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "GRS", "identifier": "CU 1014387 GRS-2024"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "certification", "name": "Higg FEM", "identifier": "HIG-FEM-2024-CN-08"}
      ]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://www.berunactivewear.com/#website",
      "url": "https://www.berunactivewear.com/",
      "name": "Berun Active Wear",
      "publisher": {"@id": "https://www.berunactivewear.com/#org"},
      "inLanguage": "en"
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "How is MOQ split across sizes? Does 300 mean 300 per SKU or 300 × 5 sizes?", "acceptedAnswer": {"@type": "Answer", "text": "Our MOQ 300 is the total piece count for one SKU — not per size. You decide the size curve. If your sales data says XS=10% / S=20% / M=30% / L=25% / XL=15%, we cut 30/60/90/75/45 pieces. Most factories quote 300 per size, which means 1,500 pieces minimum once your size curve splits. We don't."}},
        {"@type": "Question", "name": "What's your sampling cost and turnaround time?", "acceptedAnswer": {"@type": "Answer", "text": "USD 45 per sample. 5 working days on fabric we have in stock; 12 working days if your fabric is custom or sourced. You get a full one-piece sample with pattern + fabric swatch + lab dip color match. No bulk commitment required."}},
        {"@type": "Question", "name": "I don't have a tech-pack — can I still work with you?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Our 16 pattern-makers can build a tech-pack from a reference sample (a garment you already own) or a sketch. The pattern fee is USD 220 and it takes 7-14 days. After that we proceed exactly the same way as a client who brought their own tech-pack."}},
        {"@type": "Question", "name": "What does AQL 2.5 actually mean for my order?", "acceptedAnswer": {"@type": "Answer", "text": "AQL stands for Acceptable Quality Limit — it's the inspection sampling rate we use per ANSI/ASQ Z1.4. In plain English: we randomly inspect a statistically valid sample of pieces from your batch (typically 80-200 pieces depending on PO size) and check for defects. AQL 2.5 is the standard quality level retailers like Target and Costco require. We share the inspection report with every shipment."}},
        {"@type": "Question", "name": "What's your on-time delivery rate? Can I see evidence?", "acceptedAnswer": {"@type": "Answer", "text": "12-month rolling OTD is 92.4%. We log every shipment with promised date, actual date, and delay reason. The full log is reviewable under NDA for active buyers. We also send monthly OTD reports to repeat clients without being asked."}},
        {"@type": "Question", "name": "Difference between OEM, ODM, and Private Label?", "acceptedAnswer": {"@type": "Answer", "text": "OEM: you bring the tech-pack and the design — we cut and sew to your spec. ODM: you pick from our pattern library and customize color / fabric / logo — we skip the pattern-making cycle so you launch faster. Private Label: add your hangtag, care label, polybag and master carton on top of OEM or ODM. Private Label has no extra MOQ — it's an add-on."}},
        {"@type": "Question", "name": "Payment terms and FOB/CIF options?", "acceptedAnswer": {"@type": "Answer", "text": "Standard PO terms: 30% deposit on PO confirmation, 70% balance on BL (bill of lading) copy. FOB is default (you arrange shipping from our nearest port). CIF available on request. For active buyers with repeat orders, we offer NET-30 on the balance."}},
        {"@type": "Question", "name": "How do you handle batch-to-batch color consistency?", "acceptedAnswer": {"@type": "Answer", "text": "Every PO starts with a lab dip — your approved color sample. We measure ΔE (color delta) against the lab dip using a spectrophotometer at three checkpoints: fabric receiving, mid-production, and pre-shipment. ΔE must stay ≤ 1.5. The lab dip is stored in your client master file and pulled for every reorder — so a reorder 6 months later matches the original."}}
      ]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.berunactivewear.com/"}
      ]
    }
    </script>

    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/assets/css/global.css" rel="stylesheet">
    <link href="/assets/css/topbar.css" rel="stylesheet">
    <link href="/assets/css/dynamic-menu.css" rel="stylesheet">

    <script>
        window.TopBarConfig={configFile:'/assets/topbar-config.json',backgroundColor:'#1F2937',textColor:'#ffffff',linkColor:'#FCD34D',height:45,showOnMobile:false,closable:false,zIndex:1001};
        window.DynamicMenuConfig={menuFile:'/assets/menu-config.json',brandColor:'#DC2626',sticky:true};
        window.FooterConfig={configFile:'/assets/footer-config.json',backgroundColor:'#1F2937',brandColor:'#DC2626',hoverColor:'#DC2626'};
    </script>
    <link rel="preload" as="image" fetchpriority="high" href="/assets/images/hero-factory-bg.webp">

    <style>
    :root{--c1:#D51F2A;--c1d:#A9151D;--c2:#111D1B;--ca:#F5BD2B;--ct:#14201E;--cm:#59646E;--bt:#F5F7F4;--bw:#fff;--bd:rgba(17,29,27,.10);--fs:'Plus Jakarta Sans','Inter',system-ui,sans-serif;--s1:0 10px 28px rgba(17,29,27,.08);--s2:0 22px 52px rgba(17,29,27,.14);--ring:0 0 0 1px rgba(17,29,27,.08)}
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;padding-top:45px;background:#F5F7F4;background-image:linear-gradient(180deg,rgba(255,255,255,.75),rgba(245,247,244,.92));font-family:var(--fs);overflow-x:hidden;color:var(--ct);-webkit-font-smoothing:antialiased}
    @media(max-width:991px){body{padding-top:0}}
    main{display:block}img{max-width:100%;height:auto}
    main img:not([src*="certificate"]):not([src*="hero-factory"]){border-radius:8px}
    .ctr{max-width:1320px;padding-left:clamp(16px,3vw,32px);padding-right:clamp(16px,3vw,32px);margin-inline:auto}
    .ctr--n{max-width:860px}

    .sec{padding:clamp(76px,8.5vh,116px) 0;position:relative}
    .sec--w{background:#fff}.sec--t{background:linear-gradient(180deg,#F7F8F6 0%,#EEF3EE 100%)}.sec--g{background:#EEF1ED}
    .sec+.sec--w,.sec+.sec--t,.sec+.sec--g{border-top:1px solid rgba(17,29,27,.08)}
    .bk-l+.sec,.bk-d+.sec,.mc+.sec,.fc+.sec{border-top:0}
    .shd{text-align:center;margin-bottom:clamp(32px,5vw,56px);max-width:820px;margin-inline:auto}
    .srl{font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;color:var(--c1);font-weight:700;display:inline-block;padding:6px 11px;border:1px solid rgba(213,31,42,.16);border-radius:999px;background:rgba(213,31,42,.07)}
    .sh2{font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:800;color:#0f1f1e;letter-spacing:0;margin:14px 0 14px;line-height:1.12}
    .sh2::after{content:"";display:block;width:54px;height:3px;margin:18px auto 0;background:linear-gradient(90deg,var(--c1),var(--ca));border-radius:999px}
    .ssu{font-size:clamp(.9375rem,1.3vw,1.125rem);line-height:1.55;color:#65707A;max-width:60ch;margin:0 auto}
    .sec--i{background:var(--c2);color:#faf7f2}
    .sec--i .sh2{color:#fff}.sec--i .ssu{color:rgba(250,247,242,.78)}

    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;min-height:52px;padding:0 28px;font-family:var(--fs);font-size:.9375rem;font-weight:600;border-radius:7px;text-decoration:none;cursor:pointer;border:1.5px solid transparent;transition:background-color .2s ease,border-color .2s ease,color .2s ease,transform .2s ease,box-shadow .2s ease;box-shadow:none}
    .btn--p{background:var(--c1);color:#fff;border-color:var(--c1)}.btn--p:hover{background:var(--c1d);border-color:var(--c1d);color:#fff;transform:translateY(-1px);box-shadow:0 12px 26px rgba(213,31,42,.24)}
    .btn--g{background:transparent;color:#fff;border-color:rgba(255,255,255,.5)}.btn--g:hover{background:rgba(255,255,255,.12);border-color:#fff;color:#fff;transform:translateY(-1px)}
    .btn--w{background:#fff;color:var(--c1);border-color:#fff}.btn--w:hover{background:#f3f4f6;transform:translateY(-1px);box-shadow:0 6px 16px rgba(0,0,0,.12)}
    .btn--o{background:transparent;color:#fff;border:1.5px solid #fff}.btn--o:hover{background:rgba(255,255,255,.12);color:#fff}
    .btn--lk{background:none;border:none;color:rgba(255,255,255,.7);font-size:.875rem;padding:0;min-height:auto;text-decoration:underline;transition:color .2s ease}.btn--lk:hover{color:#fff}

    @keyframes rise{to{opacity:1;transform:translateY(0)}}
    .ar{opacity:0;transform:translateY(18px);animation:rise .7s cubic-bezier(.2,.8,.2,1) forwards}
    .d1{animation-delay:.05s}.d2{animation-delay:.18s}.d3{animation-delay:.3s}.d4{animation-delay:.42s}.d5{animation-delay:.55s}
    @media(prefers-reduced-motion:reduce){.ar{opacity:1;transform:none;animation:none}}
    .rv{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.rv.vis{opacity:1;transform:translateY(0)}

    /* ===== S1 HERO ===== */
    .hero{position:relative;min-height:min(86vh,920px);display:flex;align-items:center;overflow:hidden;background:#111D1B;isolation:isolate}
    .hero__bg{position:absolute;inset:0}
    .hero__bg img{width:100%;height:100%;object-fit:cover;object-position:55% 40%;filter:saturate(.92) contrast(1.08)}
    .hero__bg::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(9,18,17,.94) 0%,rgba(9,18,17,.80) 48%,rgba(9,18,17,.45) 100%),linear-gradient(180deg,rgba(9,18,17,.22),rgba(9,18,17,.72))}
    .hero__in{position:relative;z-index:1;display:grid;grid-template-columns:minmax(0,1.15fr) minmax(360px,400px);gap:clamp(32px,4vw,64px);align-items:center;padding:clamp(112px,13vh,164px) clamp(16px,3vw,32px) clamp(56px,7vh,88px)}
    .hero__cp{display:flex;flex-direction:column;gap:clamp(14px,1.6vw,22px)}
    .hero__ey{align-self:flex-start;padding:7px 11px;border:1px solid rgba(255,255,255,.18);border-radius:999px;background:rgba(255,255,255,.08);font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;font-weight:700;color:#FFD166}
    .hero__h1{font-size:clamp(2.125rem,3.4vw,3.5rem);font-weight:800;line-height:1.08;letter-spacing:0;color:#fff;margin:0;max-width:780px;text-wrap:balance;text-shadow:0 2px 18px rgba(0,0,0,.28)}
    .hero__sb{font-size:clamp(.9375rem,.5vw+.875rem,1.125rem);line-height:1.55;color:rgba(250,247,242,.88);margin:0;max-width:620px}
    .hero__sb a{color:var(--ca);text-decoration:underline}
    .hero__ct{display:flex;flex-wrap:wrap;gap:12px;margin-top:6px}
    .hero__stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:0;padding:18px 20px;margin-top:clamp(18px,2.2vw,30px);border:1px solid rgba(255,255,255,.14);border-radius:12px;background:rgba(8,16,15,.42);backdrop-filter:blur(10px);box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
    .hero__stat{min-width:0;padding:4px clamp(12px,1.3vw,20px);position:relative;display:flex;flex-direction:column;justify-content:center}
    .hero__stat:not(:last-child)::after{content:"";position:absolute;right:0;top:50%;transform:translateY(-50%);width:1px;height:36px;background:var(--c1)}
    .hero__stat-num{font-size:clamp(1.5rem,2.4vw,2rem);font-weight:800;color:#fff;line-height:1;letter-spacing:0}
    .hero__stat-num em{font-style:normal;color:#FFD166;margin-left:1px}
    .hero__stat-lbl{margin-top:6px;font-size:.6875rem;color:rgba(250,247,242,.68);letter-spacing:.04em;text-transform:uppercase;font-weight:500;line-height:1.3}
    .hero__trust{margin-top:14px;font-size:.8125rem;color:rgba(250,247,242,.55);letter-spacing:.02em}
    .hero__trust span{margin:0 6px;opacity:.4}
    .hero__scroll{margin-top:18px;font-size:.75rem;color:rgba(250,247,242,.5);letter-spacing:.04em}
    .hero__scroll a{color:#FFD166;text-decoration:none;border-bottom:1px solid rgba(255,209,102,.3)}
    .hero__scroll a:hover{border-bottom-color:#FFD166}
    .hero__visual{position:relative;display:grid;grid-template-rows:1fr 1fr;gap:14px}
    .hero__visual-thumb{border-radius:10px;overflow:hidden;border:1px solid rgba(255,255,255,.18);box-shadow:0 20px 50px rgba(0,0,0,.35)}
    .hero__visual-thumb img{width:100%;height:100%;object-fit:cover;aspect-ratio:4/3;display:block}
    .hero__visual-thumb-lbl{font-size:.6875rem;color:#FFD166;letter-spacing:.08em;text-transform:uppercase;font-weight:700;margin-top:8px;text-align:right;padding-right:4px}
    @media(max-width:1099px){.hero__in{grid-template-columns:1fr;padding:clamp(100px,12vh,140px) 0 clamp(48px,6vh,80px)}.hero__visual{order:2;grid-template-rows:auto;grid-template-columns:1fr 1fr;gap:10px}.hero__stat:not(:last-child)::after{height:28px}}
    @media(max-width:575px){.hero__h1{font-size:clamp(1.75rem,6.5vw,2.25rem)}.hero__cp{gap:12px}.hero__stats{grid-template-columns:repeat(2,minmax(0,1fr));padding:12px}.hero__stat:not(:last-child)::after{display:none}.hero__stat-num{font-size:1.25rem}.hero__ct .btn{flex:1;width:100%}}

    /* ===== S2 DATA WALL ===== */
    .dw{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(16px,2vw,24px);margin-top:clamp(28px,3vw,40px)}
    .dw__c{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;padding:clamp(22px,2.5vw,30px);position:relative;box-shadow:var(--ring);transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
    .dw__c:hover{transform:translateY(-3px);box-shadow:var(--s2);border-color:rgba(213,31,42,.18)}
    .dw__ic{position:absolute;top:20px;right:20px;color:rgba(17,29,27,.18);font-size:1.5rem}
    .dw__n{font-size:clamp(2rem,3vw,2.6rem);font-weight:800;color:var(--c1);line-height:1;letter-spacing:-.01em;margin-bottom:8px}
    .dw__n em{font-style:normal;font-size:.6em;color:var(--c1);margin-left:3px;font-weight:700}
    .dw__t{font-size:1rem;font-weight:700;color:var(--ct);margin:0 0 6px}
    .dw__d{font-size:.875rem;line-height:1.55;color:var(--cm);margin:0}
    .dw__hero{margin-bottom:clamp(28px,3vw,40px);border-radius:12px;overflow:hidden;aspect-ratio:21/9;border:1px solid rgba(17,29,27,.08);box-shadow:var(--s1)}
    .dw__hero img{width:100%;height:100%;object-fit:cover}
    @media(max-width:767px){.dw{grid-template-columns:1fr 1fr;gap:14px}.dw__c{padding:18px}}
    @media(max-width:480px){.dw{grid-template-columns:1fr}}

    /* ===== Break Bands ===== */
    .bk-d{background:linear-gradient(135deg,#111D1B 0%,#23322E 100%);text-align:center;padding:clamp(72px,8vh,110px) 0;border:0}
    .bk-d__t{font-size:clamp(1.5rem,3.2vw,2.5rem);font-weight:700;color:#fff;letter-spacing:0;line-height:1.2;max-width:34ch;margin:0 auto}
    .bk-d__s{font-size:clamp(.875rem,1.2vw,1rem);color:#FFD166;margin-top:18px;max-width:46ch;margin-left:auto;margin-right:auto;line-height:1.5;font-weight:500}
    .bk-l{background:#EAF0EA;text-align:center;padding:clamp(64px,7vh,88px) 0;border-top:1px solid rgba(17,29,27,.08);border-bottom:1px solid rgba(17,29,27,.08)}
    .bk-l__t{font-size:clamp(1.125rem,2.5vw,1.625rem);font-weight:500;color:var(--c2);line-height:1.3;max-width:42ch;margin:0 auto}

    /* ===== S4 Product Family ===== */
    .pf{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(18px,2vw,26px)}
    .pf__c{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--ring);transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
    .pf__c:hover{transform:translateY(-4px);box-shadow:var(--s2);border-color:rgba(213,31,42,.22)}
    .pf__im{aspect-ratio:4/3;overflow:hidden;background:#EEF1ED}
    .pf__im img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
    .pf__c:hover .pf__im img{transform:scale(1.04)}
    .pf__bd{padding:clamp(18px,2vw,24px);display:flex;flex-direction:column;flex:1}
    .pf__t{font-size:1.125rem;font-weight:800;color:var(--ct);margin:0 0 6px}
    .pf__d{font-size:.875rem;line-height:1.55;color:var(--cm);margin:0 0 12px}
    .pf__chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
    .pf__chip{font-size:.7rem;font-weight:600;padding:4px 10px;border-radius:20px;background:rgba(17,29,27,.06);color:#24302E;border:1px solid rgba(17,29,27,.10);white-space:nowrap}
    .pf__lk{margin-top:auto;font-size:.8125rem;font-weight:700;color:var(--c1);text-decoration:none;display:inline-flex;align-items:center;gap:6px;border-bottom:1px solid rgba(213,31,42,.3);padding-bottom:2px;align-self:flex-start;transition:gap .2s ease,border-color .2s ease}
    .pf__lk:hover{gap:10px;border-bottom-color:var(--c1)}
    @media(max-width:991px){.pf{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:575px){.pf{grid-template-columns:1fr}}

    /* ===== S5 Service Tracks ===== */
    .sv{display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(14px,1.6vw,20px);margin-bottom:clamp(28px,3vw,40px)}
    .sv__c{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:12px;padding:clamp(18px,1.8vw,22px);display:flex;flex-direction:column;box-shadow:var(--ring);transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
    .sv__c:hover{transform:translateY(-3px);box-shadow:var(--s2);border-color:rgba(213,31,42,.18)}
    .sv__ic{width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,rgba(213,31,42,.10),rgba(245,189,43,.10));color:var(--c1);font-size:1.25rem;display:flex;align-items:center;justify-content:center;margin-bottom:12px}
    .sv__t{font-size:1.0625rem;font-weight:800;color:var(--ct);margin:0 0 6px}
    .sv__d{font-size:.875rem;line-height:1.5;color:var(--cm);margin:0 0 12px}
    .sv__meta{margin-top:auto;padding-top:12px;border-top:1px solid rgba(17,29,27,.08);font-size:.75rem;color:#4F5A63;font-family:'Courier New',monospace;line-height:1.6;margin-bottom:10px}
    .sv__meta strong{color:var(--ct);font-weight:700}
    .sv__lk{font-size:.75rem;font-weight:700;color:var(--c1);text-decoration:none;display:inline-flex;align-items:center;gap:5px;transition:gap .2s ease}
    .sv__lk:hover{gap:9px}
    .sv__hero{border-radius:12px;overflow:hidden;aspect-ratio:21/9;border:1px solid rgba(17,29,27,.08);box-shadow:var(--s1)}
    .sv__hero img{width:100%;height:100%;object-fit:cover}
    @media(max-width:991px){.sv{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:480px){.sv{grid-template-columns:1fr}}

    /* ===== S6 Capacity Datasheet ===== */
    .cd{display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(28px,3vw,48px);align-items:start}
    .cd__tbl{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:12px;overflow:hidden;box-shadow:var(--ring)}
    .cd__row{display:grid;grid-template-columns:1fr 1.2fr;align-items:center;padding:14px clamp(16px,2vw,22px);border-bottom:1px solid rgba(17,29,27,.07);gap:14px}
    .cd__row:last-child{border-bottom:0}
    .cd__row:nth-child(odd){background:rgba(17,29,27,.015)}
    .cd__lbl{font-size:.875rem;font-weight:700;color:var(--ct);line-height:1.4}
    .cd__val{font-size:.875rem;font-family:'Courier New',monospace;color:#1F2937;line-height:1.5;letter-spacing:0}
    .cd__img{display:flex;flex-direction:column;gap:12px;position:sticky;top:80px}
    .cd__img-main{border-radius:12px;overflow:hidden;aspect-ratio:16/10;border:1px solid rgba(17,29,27,.08);box-shadow:var(--s1)}
    .cd__img-main img{width:100%;height:100%;object-fit:cover}
    .cd__img-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .cd__img-row > div{border-radius:8px;overflow:hidden;aspect-ratio:4/3;border:1px solid rgba(17,29,27,.08)}
    .cd__img-row img{width:100%;height:100%;object-fit:cover}
    .cd__foot{text-align:center;margin-top:clamp(28px,3vw,40px);font-size:.9375rem}
    .cd__foot a{color:var(--c1);font-weight:700;text-decoration:none;border-bottom:1px solid rgba(213,31,42,.3)}
    .cd__foot a:hover{border-bottom-color:var(--c1)}
    @media(max-width:991px){.cd{grid-template-columns:1fr}.cd__img{position:static}}

    /* ===== S7 Mid CTA ===== */
    .mc{background:linear-gradient(135deg,#C91823 0%,#E14332 100%);text-align:center;padding:clamp(56px,6vh,80px) 0}
    .mc__h{font-size:clamp(1.375rem,2.6vw,1.875rem);font-weight:800;color:#fff;margin:0 0 10px;line-height:1.2;max-width:30ch;margin-inline:auto}
    .mc__s{font-size:1rem;color:rgba(255,255,255,.92);margin:0 auto 22px;max-width:52ch;line-height:1.5}
    .mc__a{display:flex;justify-content:center;flex-wrap:wrap;gap:12px;align-items:center}
    .mc__tr{margin-top:14px;font-size:.8125rem;color:rgba(255,255,255,.7);letter-spacing:.02em}

    /* ===== S8 Comparison Table ===== */
    .cp{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;overflow:hidden;box-shadow:var(--ring)}
    .cp__head{display:grid;grid-template-columns:1.1fr 1.2fr 1.2fr;background:linear-gradient(135deg,#111D1B,#1F2937);color:#fff}
    .cp__head > div{padding:18px clamp(16px,2vw,22px);font-size:.8125rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;border-right:1px solid rgba(255,255,255,.12)}
    .cp__head > div:last-child{border-right:0;color:#FFD166}
    .cp__head > div:nth-child(2){color:rgba(255,255,255,.7)}
    .cp__row{display:grid;grid-template-columns:1.1fr 1.2fr 1.2fr;border-bottom:1px solid rgba(17,29,27,.08)}
    .cp__row:last-child{border-bottom:0}
    .cp__row > div{padding:18px clamp(16px,2vw,22px);font-size:.875rem;line-height:1.55;border-right:1px solid rgba(17,29,27,.07)}
    .cp__row > div:last-child{border-right:0}
    .cp__row-h{font-weight:800;color:var(--ct);background:rgba(17,29,27,.02);display:flex;align-items:flex-start;gap:10px}
    .cp__row-h i{color:var(--c1);font-size:1rem;flex-shrink:0;margin-top:2px}
    .cp__row-i{color:#5B6670}
    .cp__row-i::before{content:"\F659";font-family:"bootstrap-icons";color:#9AA2A9;margin-right:8px;font-weight:bold;font-size:.875rem}
    .cp__row-b{color:var(--ct);font-weight:500}
    .cp__row-b::before{content:"\F26B";font-family:"bootstrap-icons";color:var(--c1);margin-right:8px;font-weight:bold;font-size:.875rem}
    .cp__row-b strong{color:var(--c1);font-weight:700}
    @media(max-width:767px){.cp__head{display:none}.cp__row{grid-template-columns:1fr;gap:0}.cp__row > div{border-right:0;border-bottom:1px solid rgba(17,29,27,.07)}.cp__row > div:last-child{border-bottom:0}.cp__row-i::before{content:"Industry standard — "}.cp__row-b::before{content:"Berun — "}.cp__row-i::before,.cp__row-b::before{font-family:var(--fs);font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700;display:block;margin:0 0 6px}}

    /* ===== S9 Process Stepper ===== */
    .ps{display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(14px,1.5vw,20px);position:relative}
    .ps::before{content:"";position:absolute;top:34px;left:7%;right:7%;height:2px;background:linear-gradient(90deg,var(--c1),var(--ca));opacity:.4;z-index:0}
    .ps__n{position:relative;z-index:1;background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:12px;padding:clamp(16px,1.6vw,22px);display:flex;flex-direction:column;box-shadow:var(--ring);transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
    .ps__n:hover{transform:translateY(-3px);box-shadow:var(--s2);border-color:rgba(213,31,42,.18)}
    .ps__b{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--c1),#96151B);color:#fff;font-weight:800;font-size:.9375rem;display:flex;align-items:center;justify-content:center;margin-bottom:12px;box-shadow:0 8px 18px rgba(213,31,42,.22)}
    .ps__t{font-size:1rem;font-weight:800;color:var(--ct);margin:0 0 4px}
    .ps__day{font-size:.6875rem;font-family:'Courier New',monospace;color:var(--c1);font-weight:700;margin-bottom:10px;letter-spacing:.02em}
    .ps__im{border-radius:8px;overflow:hidden;aspect-ratio:4/3;margin-bottom:10px;border:1px solid rgba(17,29,27,.08)}
    .ps__im img{width:100%;height:100%;object-fit:cover}
    .ps__list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px;font-size:.75rem;line-height:1.45;color:var(--cm)}
    .ps__list li strong{color:var(--ct);font-weight:700;display:block;font-size:.6875rem;text-transform:uppercase;letter-spacing:.04em;margin-bottom:1px}
    @media(max-width:991px){.ps{grid-template-columns:1fr}.ps::before{display:none}}

    /* ===== S10 Certifications ===== */
    .cb{display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(14px,1.6vw,20px);background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;padding:clamp(20px,2.5vw,32px);margin-bottom:clamp(28px,3vw,40px);box-shadow:var(--ring)}
    .cb__l{text-align:center;padding:10px}
    .cb__l img{width:100%;aspect-ratio:3/2;object-fit:contain;background:#fff;padding:8px;filter:grayscale(1);opacity:.7;transition:filter .3s ease,opacity .3s ease}
    .cb__l:hover img{filter:grayscale(0);opacity:1}
    .cl{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;overflow:hidden;box-shadow:var(--ring)}
    .cl__row{display:grid;grid-template-columns:.6fr 1fr 1.2fr;gap:clamp(14px,2vw,24px);align-items:center;padding:clamp(16px,2vw,22px);border-bottom:1px solid rgba(17,29,27,.07)}
    .cl__row:last-child{border-bottom:0}
    .cl__thumb{aspect-ratio:3/2;border-radius:8px;overflow:hidden;background:#fff;border:1px solid rgba(17,29,27,.08);padding:6px;display:flex;align-items:center;justify-content:center}
    .cl__thumb img{width:100%;height:100%;object-fit:contain}
    .cl__name{font-size:1rem;font-weight:800;color:var(--ct);margin:0 0 4px}
    .cl__desc{font-size:.875rem;line-height:1.55;color:var(--cm);margin:0}
    .cl__meta{display:flex;flex-direction:column;align-items:flex-start;gap:6px}
    .cl__id{font-size:.75rem;font-family:'Courier New',monospace;color:#4B5563;letter-spacing:.02em;word-break:break-all}
    .cl__lk{font-size:.8125rem;font-weight:700;color:var(--c1);text-decoration:none;border-bottom:1px solid rgba(213,31,42,.3);padding-bottom:1px}
    .cl__lk:hover{border-bottom-color:var(--c1)}
    .cl__lk::after{content:" \2192"}
    .cl__foot{text-align:center;margin-top:clamp(24px,3vw,36px);font-size:.9375rem}
    .cl__foot a{color:var(--c1);font-weight:700;text-decoration:none;border-bottom:1px solid rgba(213,31,42,.3)}
    .cl__foot a:hover{border-bottom-color:var(--c1)}
    @media(max-width:767px){.cb{grid-template-columns:repeat(3,1fr)}.cl__row{grid-template-columns:1fr;gap:10px;text-align:left}.cl__meta{flex-direction:row;align-items:center;flex-wrap:wrap;gap:12px}}
    @media(max-width:480px){.cb{grid-template-columns:repeat(2,1fr)}}

    /* ===== S11 Case Cards ===== */
    .cs{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2vw,28px)}
    .cs__c{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--ring);transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
    .cs__c:hover{transform:translateY(-4px);box-shadow:var(--s2);border-color:rgba(213,31,42,.22)}
    .cs__im{aspect-ratio:16/9;overflow:hidden;background:#EEF1ED;position:relative}
    .cs__im img{width:100%;height:100%;object-fit:cover}
    .cs__tag{position:absolute;top:14px;left:14px;background:var(--c1);color:#fff;font-size:.6875rem;font-weight:700;padding:5px 11px;border-radius:20px;letter-spacing:.04em;text-transform:uppercase;z-index:1;backdrop-filter:blur(4px)}
    .cs__bd{padding:clamp(20px,2.2vw,28px);display:flex;flex-direction:column;flex:1;gap:12px}
    .cs__loc{font-size:.75rem;font-family:'Courier New',monospace;color:#4B5563;letter-spacing:.04em;text-transform:uppercase;font-weight:700;margin:0}
    .cs__t{font-size:1.125rem;font-weight:800;color:var(--ct);margin:0;line-height:1.3}
    .cs__t small{display:block;color:var(--cm);font-weight:500;font-size:.8125rem;margin-top:4px}
    .cs__metrics{display:flex;flex-wrap:wrap;gap:6px}
    .cs__metric{font-size:.7rem;font-family:'Courier New',monospace;font-weight:700;padding:4px 10px;border-radius:6px;background:rgba(17,29,27,.06);color:#24302E;border:1px solid rgba(17,29,27,.10)}
    .cs__q{position:relative;padding:14px 0 14px 18px;border-left:3px solid var(--c1);font-style:italic;font-size:.875rem;line-height:1.55;color:var(--ct);margin:0;background:rgba(213,31,42,.04);padding-right:14px;border-radius:0 8px 8px 0}
    .cs__q::before{content:"\201C";position:absolute;left:6px;top:8px;font-size:1.5rem;color:var(--c1);font-family:Georgia,serif;line-height:1}
    @media(max-width:767px){.cs{grid-template-columns:1fr}}

    /* ===== S12 Quote Cards ===== */
    .qc{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(18px,2vw,26px)}
    .qc__c{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;padding:clamp(22px,2.3vw,30px);display:flex;flex-direction:column;box-shadow:var(--ring);transition:transform .25s ease,box-shadow .25s ease}
    .qc__c:hover{transform:translateY(-4px);box-shadow:var(--s2)}
    .qc__mark{font-size:3rem;line-height:1;color:var(--c1);opacity:.28;margin:0 0 8px;font-family:Georgia,serif;font-weight:700}
    .qc__tx{font-size:.9375rem;line-height:1.7;color:var(--ct);margin:0 0 18px;flex:1}
    .qc__at{padding-top:14px;border-top:1px solid rgba(17,29,27,.08);font-size:.8125rem;color:var(--cm);font-weight:500;margin:0 0 14px}
    .qc__at strong{color:var(--ct);font-weight:700}
    .qc__im{border-radius:8px;overflow:hidden;aspect-ratio:4/3;border:1px solid rgba(17,29,27,.08)}
    .qc__im img{width:100%;height:100%;object-fit:cover}
    @media(max-width:991px){.qc{grid-template-columns:1fr}}

    /* ===== S13 Logo Wall + Data Split ===== */
    .lw{display:grid;grid-template-columns:repeat(6,1fr);gap:0;padding:clamp(20px,2.5vw,32px);background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;box-shadow:var(--ring);margin-bottom:clamp(32px,4vw,48px)}
    .lw__i{font-family:var(--fs);font-size:clamp(.8125rem,1vw,.9375rem);font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#9AA2A9;text-align:center;padding:14px 8px;border-right:1px solid rgba(17,29,27,.06);transition:color .2s ease;line-height:1.3}
    .lw__i:nth-child(6n){border-right:0}
    .lw__i:nth-child(n+7){border-top:1px solid rgba(17,29,27,.06)}
    .lw__i:hover{color:var(--ct)}
    .ds{display:grid;grid-template-columns:1fr 1fr;gap:clamp(20px,2.5vw,36px)}
    .ds__b{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:14px;padding:clamp(22px,2.5vw,32px);box-shadow:var(--ring)}
    .ds__h{font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;color:var(--c1);font-weight:700;margin:0 0 16px;padding-bottom:12px;border-bottom:1px solid rgba(213,31,42,.18)}
    .ds__row{display:flex;justify-content:space-between;align-items:center;gap:14px;padding:12px 0;border-bottom:1px solid rgba(17,29,27,.06)}
    .ds__row:last-child{border-bottom:0}
    .ds__name{font-size:.9375rem;font-weight:600;color:var(--ct);line-height:1.4}
    .ds__pct{font-size:1.125rem;font-weight:800;font-family:'Courier New',monospace;color:var(--c1);letter-spacing:0;white-space:nowrap}
    @media(max-width:767px){.lw{grid-template-columns:repeat(3,1fr)}.lw__i{border-right:1px solid rgba(17,29,27,.06)}.lw__i:nth-child(3n){border-right:0}.lw__i:nth-child(6n){border-right:1px solid rgba(17,29,27,.06)}.lw__i:nth-child(n+4){border-top:1px solid rgba(17,29,27,.06)}.ds{grid-template-columns:1fr}}
    @media(max-width:480px){.lw{grid-template-columns:repeat(2,1fr)}.lw__i:nth-child(2n){border-right:0}.lw__i:nth-child(2n+1){border-right:1px solid rgba(17,29,27,.06)}.lw__i:nth-child(n+3){border-top:1px solid rgba(17,29,27,.06)}}

    /* ===== S14 FAQ Accordion ===== */
    .faq__lead{margin-bottom:clamp(28px,3vw,40px);border-radius:12px;overflow:hidden;aspect-ratio:16/7;max-width:980px;margin-inline:auto;border:1px solid rgba(17,29,27,.08);box-shadow:var(--s1)}
    .faq__lead img{width:100%;height:100%;object-fit:cover}
    .faq{max-width:920px;margin:0 auto;display:flex;flex-direction:column;gap:10px}
    .faq__i{background:#fff;border:1px solid rgba(17,29,27,.09);border-radius:10px;overflow:hidden;box-shadow:var(--ring);transition:border-color .2s ease,box-shadow .2s ease}
    .faq__i[open]{border-color:rgba(213,31,42,.22);box-shadow:var(--s1)}
    .faq__q{padding:18px clamp(18px,2vw,24px);font-size:1rem;font-weight:700;color:var(--ct);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:flex-start;gap:14px;line-height:1.4}
    .faq__q::-webkit-details-marker{display:none}
    .faq__q::after{content:"\F282";font-family:"bootstrap-icons";color:var(--c1);font-size:.875rem;flex-shrink:0;transition:transform .2s ease;margin-top:3px}
    .faq__i[open] .faq__q::after{transform:rotate(180deg)}
    .faq__a{padding:0 clamp(18px,2vw,24px) 22px;font-size:.9375rem;line-height:1.7;color:#4F5A63}
    .faq__a p{margin:0 0 10px}
    .faq__a p:last-child{margin-bottom:0}
    .faq__a a{color:var(--c1);text-decoration:none;border-bottom:1px solid rgba(213,31,42,.3);padding-bottom:1px}
    .faq__a a:hover{border-bottom-color:var(--c1)}
    .faq__a strong{color:var(--ct);font-weight:700}
    .faq__foot{text-align:center;margin-top:clamp(28px,3vw,40px);font-size:.9375rem;color:var(--cm)}
    .faq__foot a{color:var(--c1);font-weight:700;text-decoration:none;border-bottom:1px solid rgba(213,31,42,.3);padding-bottom:1px}
    .faq__foot a:hover{border-bottom-color:var(--c1)}

    /* ===== S15 Final CTA + Form ===== */
    .fc{background:linear-gradient(135deg,#111D1B 0%,#26332F 100%);text-align:center;padding:clamp(72px,9vh,112px) 0}
    .fc__h{font-size:clamp(1.75rem,3vw,2.75rem);font-weight:800;color:#fff;margin:0 0 14px;line-height:1.15;max-width:24ch;margin-inline:auto}
    .fc__s{font-size:clamp(.9375rem,1.2vw,1.125rem);line-height:1.55;color:rgba(250,247,242,.82);max-width:60ch;margin:0 auto 28px}
    .fc__b{display:flex;justify-content:center;flex-wrap:wrap;gap:12px;margin-bottom:20px}
    .fc__tr{font-size:.8125rem;color:rgba(250,247,242,.55);letter-spacing:.02em}.fc__tr span{margin:0 6px;opacity:.4}
    .fc__form{max-width:640px;margin:28px auto 24px;background:rgba(255,255,255,.075);border:1px solid rgba(255,255,255,.16);border-radius:14px;padding:clamp(20px,3vw,32px);box-shadow:0 24px 60px rgba(0,0,0,.22),inset 0 1px 0 rgba(255,255,255,.08);text-align:left}
    .fc__fields{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .fc__field{display:flex;flex-direction:column}
    .fc__field--full{grid-column:1/-1}
    .fc__form label{font-size:.8125rem;font-weight:600;color:rgba(255,255,255,.8);margin-bottom:4px}
    .fc__form input,.fc__form textarea{background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.18);border-radius:8px;padding:10px 14px;font-family:var(--fs);font-size:.9375rem;color:#fff;transition:border-color .2s ease,background-color .2s ease,box-shadow .2s ease}
    .fc__form input::placeholder,.fc__form textarea::placeholder{color:rgba(255,255,255,.35)}
    .fc__form input:focus,.fc__form textarea:focus{outline:none;border-color:#FFD166;background:rgba(255,255,255,.12);box-shadow:0 0 0 3px rgba(255,209,102,.14)}
    .fc__form textarea{resize:vertical;min-height:80px}
    @media(max-width:575px){.fc__fields{grid-template-columns:1fr}.fc__b .btn{flex:1;width:100%}}

    /* ===== Image fallback placeholder ===== */
    .img-ph{background:#F3F4F6;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border-radius:8px;border:1px dashed #D1D5DB}
    .img-ph i{font-size:1.5rem;color:#9CA3AF}
    .img-ph span{font-size:.6875rem;color:#9CA3AF;font-weight:500;letter-spacing:.03em}

    @media(max-width:767px){.sh2::after{margin-top:14px}}
    @media(max-width:575px){body .wa-widget{right:14px!important;bottom:14px!important}body .wa-widget-button{width:56px!important;height:56px!important;min-width:56px!important;min-height:56px!important;padding:0!important;border-radius:50%!important;justify-content:center!important}body .wa-widget-button span{display:none!important}body .wa-widget-popup{right:0!important;width:calc(100vw - 28px)!important}}
    </style>
</head>
<body>
  <div id="topbar-container"></div>
  <script src="/assets/topbar.js" defer></script>
  <div id="dynamic-menu-container"></div>
  <script src="/assets/dynamic-menu.js" defer></script>

  <main id="main">

    <!-- ============ S1: HERO ============ -->
    <section class="hero" aria-labelledby="hero-h1">
      <picture class="hero__bg" aria-hidden="true">
        <img src="/assets/images/hero-factory-bg.webp" alt="" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="sync">
      </picture>
      <div class="ctr hero__in">
        <div class="hero__cp">
          <span class="hero__ey ar d1">For sourcing teams that need spec on paper and spec on goods</span>
          <h1 class="hero__h1 ar d2" id="hero-h1">Custom Activewear Manufacturer &mdash; OEM, ODM and Private Label</h1>
